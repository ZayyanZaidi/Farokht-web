# --- DATABASE CONFIGURATION ---
# MongoDB connection string (Replace with your live MongoDB Atlas connection URL)
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.mongodb.net/farokht?retryWrites=true&w=majority

# --- SECURITY & SESSIONS ---
# Secret key used for signing and verifying JSON Web Tokens (JWT) for authentication
JWT_SECRET=farokht_production_jwt_secret_key_987654321

# --- RUNTIME ENVIRONMENT ---
# Environment mode (production optimizes performance and triggers production static routes)
NODE_ENV=production

# The port for the backend web service (Render manages this, but this serves as a baseline fallback)
PORT=5000

# --- SEED ADMIN PROFILE ---
# Initial administrator account email (severs seed during first startup)
ADMIN_EMAIL=admin@farokht.pk

# Initial administrator password
ADMIN_PASSWORD=FarokhtAdmin123!

# --- ML & INTEGRATION SERVICES ---
# URL for the external Farokht datasets API
FAROKHT_API_URL=https://svc-frkt-app-x8d4k2.farokht.store/api/v1/ml/datasets

# API Key for accessing the external Farokht dataset services
FAROKHT_API_KEY=your_farokht_external_api_key
